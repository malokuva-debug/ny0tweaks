{
  "rewrites": [
    { "source": "/win", "destination": "/win.ps1" }
  ],
  "headers": [
    {
      "source": "/win",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*\\.ps1)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
